# Supertonic TTS WebUI - Environment Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:5173

# Supertonic Model
SUPERTONIC_MODEL=supertonic-3-voice-model
SUPERTONIC_MODEL_URL=https://huggingface.co/supertonic/supertonic-3/resolve/main/model.onnx

# Audio Settings
SAMPLE_RATE=24000
MAX_TEXT_LENGTH=5000

# Quality Settings (8-64)
DEFAULT_QUALITY_STEPS=32

# Cache Settings
CACHE_MAX_AGE_HOURS=24
CACHE_MAX_SIZE_MB=500

# History Settings
HISTORY_MAX_ITEMS=200

# Logging
LOG_LEVEL=INFO
</write_to_file>